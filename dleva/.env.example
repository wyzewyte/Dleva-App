# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-app.up.railway.app

# Database (Production: Railway provides DATABASE_URL automatically)
# For Localhost: fill these individual fields
DB_NAME=dleva_db
DB_USER=dleva_user
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432

# Redis for WebSockets (Production: Railway provides REDIS_URL automatically)
REDIS_URL=redis://your-redis-url

# Paystack Payment (Use LIVE keys in production)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_API_URL=https://api.paystack.co
PAYSTACK_CALLBACK_URL=http://localhost:5173/payment/callback

# Twilio SMS Service
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_SENDER_PHONE=+1234567890

# Firebase Cloud Messaging
FIREBASE_SERVICE_ACCOUNT_PATH=serviceAccountKey.json