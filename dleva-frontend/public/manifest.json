{
  "name": "D-Leva Rider",
  "short_name": "DlevaRider",
  "description": "D-Leva Rider - Real-time delivery tracking and management",
  "start_url": "/rider/dashboard",
  "scope": "/rider/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#ffffff",
  "theme_color": "#FF6B00",
  "categories": ["productivity", "logistics"],
  "icons": [
    {
      "src": "/vite.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/vite.svg",
      "sizes": "192x192",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/vite.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/vite.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "View Deliveries",
      "short_name": "Deliveries",
      "description": "View active deliveries",
      "url": "/rider/orders",
      "icons": [
        {
          "src": "/vite.svg",
          "sizes": "96x96",
          "type": "image/svg+xml"
        }
      ]
    },
    {
      "name": "View Earnings",
      "short_name": "Earnings",
      "description": "View your earnings",
      "url": "/rider/earnings",
      "icons": [
        {
          "src": "/vite.svg",
          "sizes": "96x96",
          "type": "image/svg+xml"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+dleva",
      "url": "/rider/delivery?order=%s"
    }
  ]
}
